alembic/versions/__pycache__/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Ruff / mypy cache ─────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── Distribution ─────────────────────────────────────────────────────────────
*.tar.gz
*.whl
